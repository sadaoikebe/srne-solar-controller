          },
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"modbus\" and r._field == \"value\")\n  |> filter(fn: (r) =>\n      r.name == \"load_active_l1\" or r.name == \"load_active_l2\" or\n      r.name == \"grid_l1\"        or r.name == \"grid_l2\" or\n      r.name == \"battery_voltage_powmr\"              or\n      r.name == \"battery_current_powmr\"              or\n      r.name == \"battery_voltage_growatt\"            or\n      r.name == \"battery_current_growatt_charge\"     or\n      r.name == \"battery_current_growatt_draw\"\n  )\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n  |> group()\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"name\"], valueColumn: \"_value\")\n  |> map(fn: (r) => {\n      load_total = (if exists r.load_active_l1 then r.load_active_l1 else 0.0) +\n                  (if exists r.load_active_l2 then r.load_active_l2 else 0.0)\n      grid_total = (if exists r.grid_l1 then r.grid_l1 else 0.0) +\n                  (if exists r.grid_l2 then r.grid_l2 else 0.0)\n      p_powmr    = if exists r.battery_voltage_powmr and exists r.battery_current_powmr\n                  then -float(v: r.battery_voltage_powmr) * float(v: r.battery_current_powmr)\n                  else 0.0\n      p_grow     = if exists r.battery_voltage_growatt and\n                      exists r.battery_current_growatt_charge and\n                      exists r.battery_current_growatt_draw\n                  then float(v: r.battery_voltage_growatt) *\n                       (float(v: r.battery_current_growatt_charge) -\n                        float(v: r.battery_current_growatt_draw))\n                  else 0.0\n      return {\n        _time:          r._time,\n        \"Load\":         load_total,\n        \"Grid\":         grid_total,\n        \"Battery Power\": p_powmr + p_grow\n      }\n  })",
