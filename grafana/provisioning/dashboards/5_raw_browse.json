  "description": "Raw uint16 capture of Growatt input registers 0-95. Use this to identify and label unknown registers before adding them to regmap.yaml.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
