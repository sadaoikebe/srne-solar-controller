  "panels": [
    {
      "datasource": {
        "type": "influxdb",
        "uid": "srne-influxdb"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": true
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull", "min", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Raw uint16 — selected Growatt registers",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "srne-influxdb" },
          "query": "from(bucket: \"${raw_bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"modbus_raw\" and r._field == \"value\" and r.device == \"growatt\")\n  |> filter(fn: (r) => contains(value: r.reg, set: ${reg:json}))\n  |> keep(columns: [\"_time\", \"_value\", \"reg\"])\n  |> rename(columns: {reg: \"register\"})",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "srne-influxdb"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": true
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "id": 2,
      "description": "32-bit candidate decoder for ${pair_hi}-${pair_lo}. Both byte orders are plotted — pick the one that's monotonic / non-negative / physically plausible. Apply scale via the regmap.yaml entry once identified.",
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "min", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "32-bit pair candidate: regs ${pair_hi}-${pair_lo} (both byte orders)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "srne-influxdb" },
          "query": "import \"experimental\"\n\nbase = from(bucket: \"${raw_bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"modbus_raw\" and r._field == \"value\" and r.device == \"growatt\")\n  |> filter(fn: (r) => r.reg == \"${pair_hi}\" or r.reg == \"${pair_lo}\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"reg\"], valueColumn: \"_value\")\n\nhi_first = base\n  |> map(fn: (r) => ({_time: r._time, _value: float(v: r.${pair_hi}) * 65536.0 + float(v: r.${pair_lo}), order: \"hi-lo (${pair_hi} first)\"}))\n\nlo_first = base\n  |> map(fn: (r) => ({_time: r._time, _value: float(v: r.${pair_lo}) * 65536.0 + float(v: r.${pair_hi}), order: \"lo-hi (${pair_lo} first)\"}))\n\nunion(tables: [hi_first, lo_first])",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["solar", "raw", "diagnostics"],
  "templating": {
    "list": [
      {
        "name": "raw_bucket",
        "type": "constant",
        "label": "Raw bucket",
        "query": "solar_raw",
        "current": { "selected": true, "text": "solar_raw", "value": "solar_raw" },
        "options": [{ "selected": true, "text": "solar_raw", "value": "solar_raw" }],
        "hide": 0
      },
      {
        "name": "reg",
        "type": "query",
        "label": "Register(s)",
        "datasource": { "type": "influxdb", "uid": "srne-influxdb" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${raw_bucket}\", tag: \"reg\", predicate: (r) => r._measurement == \"modbus_raw\" and r.device == \"growatt\")",
        "refresh": 2,
        "multi": true,
        "includeAll": false,
        "sort": 3,
        "current": { "selected": false, "text": ["76", "77"], "value": ["76", "77"] }
      },
      {
        "name": "pair_hi",
        "type": "textbox",
        "label": "32-bit hi register",
        "query": "76",
        "current": { "selected": true, "text": "76", "value": "76" }
      },
      {
        "name": "pair_lo",
        "type": "textbox",
        "label": "32-bit lo register",
        "query": "77",
        "current": { "selected": true, "text": "77", "value": "77" }
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Solar — Raw Register Browser",
  "uid": "solar-raw-browse",
  "version": 1,
  "weekStart": ""
}
