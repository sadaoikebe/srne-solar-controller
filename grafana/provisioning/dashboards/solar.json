      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "srne-influxdb"
          },
          "query": "common =\n  from(bucket: v.defaultBucket)\n    |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n    |> filter(fn: (r) => r._measurement == \"modbus\" and r._field == \"value\")\n    |> filter(fn: (r) =>\n      r.name =~ /battery_(voltage|current)_powmr/ or\n      r.name =~ /battery_voltage_growatt/ or\n      r.name =~ /battery_current_growatt_(charge|draw)/\n    )\n    |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n    |> group()\n\npivoted =\n  common\n    |> pivot(rowKey: [\"_time\"], columnKey: [\"name\"], valueColumn: \"_value\")\n\np_powmr =\n  pivoted\n    |> filter(fn: (r) => exists r.battery_voltage_powmr and exists r.battery_current_powmr)\n    |> map(fn: (r) => ({\n        r with\n        _value: - float(v: r.battery_voltage_powmr) * float(v: r.battery_current_powmr),\n        name: \"battery_power_powmr\",\n        _measurement: \"modbus\",\n        _field: \"value\"\n    }))\n    |> keep(columns: [\"_time\",\"_start\",\"_stop\",\"_value\",\"_measurement\",\"_field\",\"name\"])\n    |> group(columns: [\"name\"], mode: \"by\")\n\np_growatt =\n  pivoted\n    |> filter(fn: (r) =>\n      exists r.battery_voltage_growatt and\n      exists r.battery_current_growatt_charge and\n      exists r.battery_current_growatt_draw\n    )\n    |> map(fn: (r) => ({\n        r with\n        _value: float(v: r.battery_voltage_growatt) *\n                ( float(v: r.battery_current_growatt_charge)\n                - float(v: r.battery_current_growatt_draw) ),\n        name: \"battery_power_growatt\",\n        _measurement: \"modbus\",\n        _field: \"value\"\n    }))\n    |> keep(columns: [\"_time\",\"_start\",\"_stop\",\"_value\",\"_measurement\",\"_field\",\"name\"])\n    |> group(columns: [\"name\"], mode: \"by\")\n\np_total =\n  union(tables: [p_powmr, p_growatt])\n    |> group(columns: [\"_time\",\"_start\",\"_stop\"], mode: \"by\")\n    |> sum(column: \"_value\")\n    |> map(fn: (r) => ({\n        r with\n        name: \"battery_power_total\",\n        _measurement: \"modbus\",\n        _field: \"value\"\n    }))\n    |> group(columns: [\"name\"], mode: \"by\")\n\nunion(tables: [p_powmr, p_growatt, p_total])\n",
          "refId": "A"
        }
      ],
