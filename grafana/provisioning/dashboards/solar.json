          },
          "query": "data =\n  from(bucket: v.defaultBucket)\n    |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n    |> filter(fn: (r) => r._measurement == \"modbus\" and r._field == \"value\")\n    |> filter(fn: (r) => r.name =~ /pv[1-4]_power/)\n    |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n    |> keep(columns: [\"_time\",\"_value\",\"name\"])\n\nwide =\n  data\n    |> pivot(rowKey: [\"_time\"], columnKey: [\"name\"], valueColumn: \"_value\")\n\ntotal =\n  wide\n    |> map(fn: (r) => ({\n        _time: r._time,\n        _value:\n          float(v: (if exists r.pv1_power then r.pv1_power else 0.0)) +\n          float(v: (if exists r.pv2_power then r.pv2_power else 0.0)) +\n          float(v: (if exists r.pv3_power then r.pv3_power else 0.0)) +\n          float(v: (if exists r.pv4_power then r.pv4_power else 0.0)),\n        name: \"pv_total_power\"\n    }))\n    |> keep(columns: [\"_time\",\"_value\",\"name\"])\n\nunion(tables: [data, total])\n",
          "refId": "A"
        }
      ],
