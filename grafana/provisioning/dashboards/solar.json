          "query": "raw =\n  from(bucket: v.defaultBucket)\n    |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n    |> filter(fn: (r) => r._measurement == \"modbus\" and r._field == \"value\")\n    |> filter(fn: (r) => r.name =~ /_daily/)\n    |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n    |> keep(columns: [\"_time\",\"_value\",\"name\"])\n\ndata =\n  raw\n    |> duplicate(column: \"name\", as: \"_field\")\n    |> set(key: \"_measurement\", value: \"modbus\")\n\npv_daily_sum =\n  raw\n    |> filter(fn: (r) => r.name == \"pv_powmr_daily\" or r.name == \"pv3_daily\")\n    |> group()\n    |> pivot(rowKey: [\"_time\"], columnKey: [\"name\"], valueColumn: \"_value\")\n    |> map(fn: (r) => ({\n        _time: r._time,\n        _value: (if exists r.pv_powmr_daily then r.pv_powmr_daily else 0.0)\n              + (if exists r.pv3_daily then r.pv3_daily else 0.0),\n        _field: \"pv_daily_sum\",\n        _measurement: \"calc\"\n      }))\n\ngrid_daily_sum =\n  raw\n    |> filter(fn: (r) => r.name == \"grid_to_batt_daily\" or r.name == \"grid_to_load_daily\")\n    |> group()\n    |> pivot(rowKey: [\"_time\"], columnKey: [\"name\"], valueColumn: \"_value\")\n    |> map(fn: (r) => ({\n        _time: r._time,\n        _value: (if exists r.grid_to_batt_daily then r.grid_to_batt_daily else 0.0)\n              + (if exists r.grid_to_load_daily then r.grid_to_load_daily else 0.0),\n        _field: \"grid_daily_sum\",\n        _measurement: \"calc\"\n      }))\n\nunion(tables: [data, pv_daily_sum, grid_daily_sum])\n  |> group(columns: [\"_measurement\",\"_field\"])\n  |> keep(columns: [\"_time\",\"_value\",\"_field\",\"_measurement\"])\n",
