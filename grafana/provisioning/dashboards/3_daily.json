      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "srne-influxdb"
          },
          "query": "import \"timezone\"\nimport \"math\"\n\njst = timezone.location(name: \"Asia/Tokyo\")\n\nfrom(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"modbus\" and r._field == \"value\")\n  |> filter(fn: (r) =>\n      r.name == \"pv_powmr_daily\" or\n      r.name == \"pv3_daily\" or\n      r.name == \"load_daily\" or\n      r.name == \"grid_to_load_daily\" or\n      r.name == \"grid_to_batt_daily\" or\n      r.name == \"batt_charge_daily\" or\n      r.name == \"batt_discharge_daily\"\n  )\n  |> aggregateWindow(every: 1d, location: jst, fn: (tables=<-, column) =>\n      tables |> sort(columns: [\"_time\"]) |> tail(n: 15) |> max(column: \"_value\"),\n    createEmpty: false)\n  |> group()\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"name\"], valueColumn: \"_value\")\n  |> map(fn: (r) => {\n      pv   = (if exists r.pv_powmr_daily then r.pv_powmr_daily else 0.0) +\n             (if exists r.pv3_daily      then r.pv3_daily      else 0.0)\n      load =  if exists r.load_daily           then r.load_daily           else 0.0\n      g2l  =  if exists r.grid_to_load_daily   then r.grid_to_load_daily   else 0.0\n      g2b  =  if exists r.grid_to_batt_daily   then r.grid_to_batt_daily   else 0.0\n      bc   =  if exists r.batt_charge_daily    then r.batt_charge_daily    else 0.0\n      bd   =  if exists r.batt_discharge_daily then r.batt_discharge_daily else 0.0\n      return {\n        _time:                  time(v: int(v: r._time) - 1),\n        \"PV (kWh)\":             math.round(x: pv          * 10.0) / 10.0,\n        \"Load (kWh)\":           math.round(x: load        * 10.0) / 10.0,\n        \"Batt Charge (kWh)\":    math.round(x: bc          * 10.0) / 10.0,\n        \"Batt Discharge (kWh)\": math.round(x: bd          * 10.0) / 10.0,\n        \"Grid Import (kWh)\":    math.round(x: (g2l + g2b) * 10.0) / 10.0\n      }\n  })\n  |> sort(columns: [\"_time\"], desc: true)\n",
          "refId": "A"
        }
      ],
      "title": "Daily Statistics — One Row per Day",
      "type": "table"
    }
